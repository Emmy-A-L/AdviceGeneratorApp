{
  "expo": {
    "name": "AdviceGeneratorApp",
    "slug": "AdviceGeneratorApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/advice-logo-transparent.png",
    "scheme": "advicegeneratorapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#272727",
        "foregroundImage": "./src/assets/images/advice-logo-transparent.png",
        "backgroundImage": "./src/assets/images/advice-logo-transparent.png",
        "monochromeImage": "./src/assets/images/advice-logo-transparent.png"
      },
      "predictiveBackGestureEnabled": false,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/advice-logo-transparent.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/advice-logo-transparent.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
