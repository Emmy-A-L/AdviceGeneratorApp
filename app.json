{
  "expo": {
    "name": "AdviceGeneratorApp",
    "slug": "AdviceGeneratorApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/main-icon.png",
    "scheme": "advicegenerator",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#272727",
        "foregroundImage": "./src/assets/images/main-icon.png",
        "backgroundImage": "./src/assets/images/main-icon.png",
        "monochromeImage": "./src/assets/images/main-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "edgeToEdgeEnabled": true,
      "package": "com.niotron.emmanuellot95.AdviceGenerator"
    },
    "web": {
      "output": "static",
      "favicon": "./src/assets/images/main-icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/main-icon.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#272727"
        }
      ],
      "expo-font",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3138057547675144~9151381496",
          "iosAppId": "ca-app-pub-3138057547675144~9151381496"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ca9bacdc-ce45-4b84-b94c-e821604c2d01"
      }
    }
  }
}
